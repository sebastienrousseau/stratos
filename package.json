{
  "name": "@cloudcdn/stratos",
  "version": "0.0.2",
  "description": "Official command-line client for CloudCDN — full control plane in a single zero-dep Node script.",
  "type": "module",
  "main": "stratos.mjs",
  "bin": {
    "stratos": "stratos.mjs"
  },
  "files": [
    "stratos.mjs",
    "install/",
    "README.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "stratos": "node stratos.mjs",
    "test": "node --test test/parse.test.mjs test/router.test.mjs test/signed.test.mjs test/http.test.mjs test/mcp.test.mjs test/doctor-bench.test.mjs test/diff-pagination.test.mjs",
    "version-print": "node stratos.mjs version",
    "health": "node stratos.mjs health"
  },
  "keywords": [
    "cloudcdn",
    "cli",
    "cdn",
    "purge",
    "signed-url",
    "image-cdn",
    "mcp",
    "model-context-protocol",
    "edge",
    "cloudflare-pages"
  ],
  "author": "Sebastien Rousseau <sebastian.rousseau@gmail.com> (https://sebastienrousseau.com)",
  "license": "MIT",
  "homepage": "https://github.com/sebastienrousseau/stratos#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sebastienrousseau/stratos.git"
  },
  "bugs": {
    "url": "https://github.com/sebastienrousseau/stratos/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
